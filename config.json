{
  "log": {
    "loglevel": "warning"
  },
  "dns": {
    "servers": ["1.1.1.1", "8.8.8.8"]
  },
  "inbounds": [
    {
      "port": 10000,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "tag": "vless-ws",
      "settings": {
        "clients": [{ "id": "saeka", "level": 0 }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "/vless-saeka-ws" },
        "sockopt": { "tcpFastOpen": true, "tcpNoDelay": true }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    },
    {
      "port": 10001,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "tag": "vless-httpupgrade",
      "settings": {
        "clients": [{ "id": "saeka", "level": 0 }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "httpupgrade",
        "httpupgradeSettings": { "path": "/vless-saeka-hu" },
        "sockopt": { "tcpFastOpen": true, "tcpNoDelay": true }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    },
    {
      "port": 10002,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "tag": "vless-grpc",
      "settings": {
        "clients": [{ "id": "saeka", "level": 0 }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "grpcSettings": { "serviceName": "vless-saeka-grpc" },
        "sockopt": { "tcpFastOpen": true, "tcpNoDelay": true }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    },
    {
      "port": 10003,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "tag": "vless-xhttp",
      "settings": {
        "clients": [{ "id": "saeka", "level": 0 }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": { "path": "/vless-saeka-xhttp" },
        "sockopt": { "tcpFastOpen": true, "tcpNoDelay": true }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct" },
    { "protocol": "blackhole", "tag": "block", "settings": { "response": { "type": "http" } } }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "outboundTag": "block",
        "domain": [
          "geosite:category-ads-all",
          "domain:doubleclick.net",
          "domain:googleads.g.doubleclick.net",
          "domain:adservice.google.com",
          "domain:ads.youtube.com",
          "domain:youtube-ui.l.google.com",
          "domain:ytimg.l.google.com",
          "domain:pagead2.googlesyndication.com",
          "domain:partnerad.l.google.com",
          "domain:adserver.yahoo.com",
          "domain:flurry.com",
          "domain:analytics.google.com"
        ]
      },
      { "type": "field", "network": "tcp,udp", "outboundTag": "direct" }
    ]
  }
}