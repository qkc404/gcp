#!/data/data/com.termux/files/usr/bin/bash
set -e

# ==============================================
#        VLESS GCP DEPLOYER - TERMUX AIO
#        github.com/qkc404/gcp-full
# ==============================================

# --- Colors ---
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

show_banner() {
    clear
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo -e "${BOLD}${CYAN}   VLESS GCP DEPLOYER - TERMUX AIO      ${RESET}"
    echo -e "${BOLD}${CYAN}   github.com/qkc404/gcp-full           ${RESET}"
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo ""
}

error_exit() {
    echo -e "${RED}[ERROR]${RESET} $1" >&2
    exit 1
}

spinner() {
    local pid=$1
    local message=$2
    local spinstr='|/-\'
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r${CYAN}[%s]${RESET} %s" "${spinstr:i++%4:1}" "$message"
        sleep 0.2
    done
    printf "\r${GREEN}[OK]${RESET} %s\n" "$message"
}

check_gcloud() {
    if ! command -v gcloud &> /dev/null; then
        return 1
    fi
    return 0
}

check_auth() {
    if ! gcloud auth list --format="value(account)" 2>/dev/null | grep -q "@"; then
        return 1
    fi
    return 0
}

install_dependencies() {
    show_banner
    echo -e "${YELLOW}[*]${RESET} Installing dependencies..."
    pkg update -y > /dev/null 2>&1
    pkg upgrade -y > /dev/null 2>&1
    pkg install -y python openssh curl which wget jq python-pip qrencode > /dev/null 2>&1 &
    spinner $! "Installing packages"
    echo -e "${GREEN}[OK]${RESET} Dependencies installed."
    echo ""
}

install_gcloud() {
    show_banner
    if check_gcloud; then
        echo -e "${GREEN}[OK]${RESET} gcloud already installed."
        echo ""
        return
    fi
    
    echo -e "${YELLOW}[*]${RESET} Installing Google Cloud SDK..."
    echo -e "${CYAN}[!]${RESET} This may take 2-3 minutes."
    
    # Install Python 3.11 (compatible with gcloud)
    pkg install python-3.11 -y > /dev/null 2>&1 2>/dev/null || pkg install python -y > /dev/null 2>&1
    
    # Download and install gcloud
    curl -o $PREFIX/bin/gcloud-install.sh https://sdk.cloud.google.com > /dev/null 2>&1
    chmod +x $PREFIX/bin/gcloud-install.sh
    $PREFIX/bin/gcloud-install.sh --install-dir=$PREFIX --disable-prompts > /dev/null 2>&1 &
    spinner $! "Installing Google Cloud SDK"
    rm $PREFIX/bin/gcloud-install.sh
    
    # Configure environment
    echo 'export PATH="$PREFIX/google-cloud-sdk/bin:$PATH"' >> ~/.bashrc
    echo 'export CLOUDSDK_PYTHON="$PREFIX/bin/python"' >> ~/.bashrc
    export PATH="$PREFIX/google-cloud-sdk/bin:$PATH"
    export CLOUDSDK_PYTHON="$PREFIX/bin/python"
    
    # Install required Python module
    python -m pip install --quiet six > /dev/null 2>&1
    
    echo -e "${GREEN}[OK]${RESET} Google Cloud SDK installed."
    echo ""
}

authenticate() {
    show_banner
    if ! check_gcloud; then
        echo -e "${RED}[ERROR]${RESET} gcloud not installed. Run option 1 first."
        read -p "Press Enter to return..."
        return
    fi
    
    echo -e "${YELLOW}[*]${RESET} Starting authentication..."
    echo -e "${CYAN}[!]${RESET} A URL will appear. Open it in your browser."
    echo -e "${CYAN}[!]${RESET} Log in with your Qwiklabs Google account."
    echo -e "${CYAN}[!]${RESET} Paste the verification code back here."
    echo ""
    
    if ! gcloud auth login --no-launch-browser; then
        echo -e "${RED}[ERROR]${RESET} Authentication failed."
    else
        echo -e "${GREEN}[OK]${RESET} Authentication complete."
    fi
    echo ""
    read -p "Press Enter to return..."
}

set_project() {
    show_banner
    if ! check_gcloud; then
        echo -e "${RED}[ERROR]${RESET} gcloud not installed. Run option 1 first."
        read -p "Press Enter to return..."
        return
    fi
    
    echo -e "${YELLOW}[?]${RESET} Enter the Qwiklabs Project ID:"
    echo -e "${CYAN}    (Find this in the GCP Console URL)${RESET}"
    read -p "Project ID: " PROJECT_ID
    
    if [ -z "$PROJECT_ID" ]; then
        echo -e "${RED}[ERROR]${RESET} Project ID cannot be empty."
    else
        if gcloud config set project "$PROJECT_ID" 2>/dev/null; then
            echo -e "${GREEN}[OK]${RESET} Project set to: $PROJECT_ID"
        else
            echo -e "${RED}[ERROR]${RESET} Failed to set project."
        fi
    fi
    echo ""
    read -p "Press Enter to return..."
}

quick_deploy() {
    show_banner
    if ! check_gcloud; then
        echo -e "${RED}[ERROR]${RESET} gcloud not installed. Run option 1 first."
        read -p "Press Enter to return..."
        return
    fi
    
    if ! check_auth; then
        echo -e "${RED}[ERROR]${RESET} Not authenticated. Run option 2 first."
        read -p "Press Enter to return..."
        return
    fi
    
    echo -e "${YELLOW}[*]${RESET} Quick Deploy with default settings..."
    echo -e "${CYAN}    Service: prvtspyyy404 | CPU: 2 vCPU | RAM: 4 GiB${RESET}"
    echo ""
    echo -e "${CYAN}[!]${RESET} Opening GCP Console in browser..."
    termux-open-url "https://console.cloud.google.com/" 2>/dev/null || echo -e "${YELLOW}[!]${RESET} Please open GCP Console manually."
    echo ""
    echo -e "${CYAN}[ACTION REQUIRED]${RESET} In your browser:"
    echo "  1. Click the Cloud Shell icon (>_) in the top-right."
    echo "  2. Click 'Authorize' if prompted."
    echo "  3. Wait for the terminal prompt ($) to appear."
    echo ""
    read -p "Press Enter AFTER Cloud Shell is ready..."
    echo ""
    echo -e "${YELLOW}[*]${RESET} Connecting to Cloud Shell..."
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    # Execute remote deployment
    gcloud cloud-shell ssh --authorize-session --command="
        curl -sL https://raw.githubusercontent.com/qkc404/gcp-full/main/deploy.sh -o deploy.sh && \
        chmod +x deploy.sh && \
        echo -e 'prvtspyyy404\n4\n3' | ./deploy.sh 2>&1
    "
    
    local EXIT_CODE=$?
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    if [ $EXIT_CODE -eq 0 ]; then
        echo -e "${GREEN}[OK]${RESET} Deployment successful!"
        
        # Try to fetch saved URI
        echo ""
        echo -e "${CYAN}[*]${RESET} Fetching connection details..."
        gcloud cloud-shell ssh --authorize-session --command="cat /tmp/vless-uri.txt 2>/dev/null" 2>/dev/null | while read -r URI; do
            if [ -n "$URI" ]; then
                echo ""
                echo -e "${BOLD}${GREEN}VLESS URI:${RESET}"
                echo -e "${CYAN}$URI${RESET}"
                echo ""
                echo -e "${YELLOW}[*]${RESET} Generating QR code..."
                echo "$URI" | qrencode -t ANSIUTF8 2>/dev/null || echo -e "${YELLOW}[!]${RESET} QR code generation skipped."
            fi
        done
    else
        echo -e "${RED}[ERROR]${RESET} Deployment failed with exit code: $EXIT_CODE"
        echo -e "${YELLOW}[!]${RESET} Ensure Cloud Shell is active and project is set correctly."
    fi
    
    echo ""
    read -p "Press Enter to return..."
}

custom_deploy() {
    show_banner
    if ! check_gcloud; then
        echo -e "${RED}[ERROR]${RESET} gcloud not installed. Run option 1 first."
        read -p "Press Enter to return..."
        return
    fi
    
    if ! check_auth; then
        echo -e "${RED}[ERROR]${RESET} Not authenticated. Run option 2 first."
        read -p "Press Enter to return..."
        return
    fi
    
    echo -e "${YELLOW}[*]${RESET} Custom Deployment"
    echo ""
    read -p "Service name [default: prvtspyyy404]: " SNAME
    SNAME="${SNAME:-prvtspyyy404}"
    echo ""
    echo -e "${CYAN}Select CPU/RAM:${RESET}"
    echo "  [1] 1 vCPU, 1 GiB"
    echo "  [2] 1 vCPU, 2 GiB"
    echo "  [3] 2 vCPU, 2 GiB"
    echo "  [4] 2 vCPU, 4 GiB (RECOMMENDED)"
    echo "  [5] 4 vCPU, 4 GiB"
    read -p "Choice [1-5]: " CPURAM
    CPURAM="${CPURAM:-4}"
    echo ""
    echo -e "${CYAN}Select output:${RESET}"
    echo "  [1] QR Code only"
    echo "  [2] Ping Monitor only"
    echo "  [3] Both"
    read -p "Choice [1-3]: " OUTPUT
    OUTPUT="${OUTPUT:-3}"
    
    echo ""
    echo -e "${CYAN}[!]${RESET} Opening GCP Console in browser..."
    termux-open-url "https://console.cloud.google.com/" 2>/dev/null
    echo ""
    echo -e "${CYAN}[ACTION REQUIRED]${RESET} Start Cloud Shell in browser, then press Enter."
    read -p "Press Enter when ready..."
    echo ""
    echo -e "${YELLOW}[*]${RESET} Deploying..."
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    gcloud cloud-shell ssh --authorize-session --command="
        curl -sL https://raw.githubusercontent.com/qkc404/gcp-full/main/deploy.sh -o deploy.sh && \
        chmod +x deploy.sh && \
        echo -e '$SNAME\n$CPURAM\n$OUTPUT' | ./deploy.sh 2>&1
    "
    
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo -e "${GREEN}[OK]${RESET} Deployment complete."
    echo ""
    read -p "Press Enter to return..."
}

full_setup() {
    install_dependencies
    install_gcloud
    authenticate
    set_project
    show_banner
    echo -e "${GREEN}[OK]${RESET} Full setup complete!"
    echo -e "${CYAN}[*]${RESET} You can now run Quick Deploy (option 3)."
    echo ""
    read -p "Press Enter to return..."
}

main_menu() {
    while true; do
        show_banner
        echo -e "${BOLD}${CYAN}              MAIN MENU                 ${RESET}"
        echo -e "${BOLD}${CYAN}=========================================${RESET}"
        echo ""
        echo -e "  ${BOLD}[1]${RESET} Full Setup (Install Everything)"
        echo -e "  ${BOLD}[2]${RESET} Authenticate / Set Project"
        echo -e "  ${BOLD}[3]${RESET} Quick Deploy (Browser + Auto)"
        echo -e "  ${BOLD}[4]${RESET} Custom Deploy"
        echo -e "  ${BOLD}[5]${RESET} Exit"
        echo ""
        read -p "Select option [1-5]: " CHOICE
        
        case $CHOICE in
            1) full_setup ;;
            2) 
                authenticate
                set_project
                ;;
            3) quick_deploy ;;
            4) custom_deploy ;;
            5) echo -e "${GREEN}Goodbye.${RESET}"; exit 0 ;;
            *) echo -e "${RED}Invalid choice.${RESET}"; sleep 1 ;;
        esac
    done
}

# Create gcp command alias
setup_alias() {
    mkdir -p ~/.termux/bin
    cat > ~/.termux/bin/gcp <<'GCP_EOF'
#!/data/data/com.termux/files/usr/bin/bash
~/.termux-setup.sh
GCP_EOF
    chmod +x ~/.termux/bin/gcp
    if ! grep -q ".termux/bin" ~/.bashrc; then
        echo 'export PATH="$HOME/.termux/bin:$PATH"' >> ~/.bashrc
    fi
}

# Main execution
main() {
    setup_alias
    
    # Check if first run
    if [ ! -f ~/.termux/.gcp_configured ]; then
        show_banner
        echo -e "${YELLOW}[!]${RESET} First time setup detected."
        echo -e "${CYAN}[*]${RESET} This will install all dependencies (3-5 minutes)."
        echo ""
        read -p "Press Enter to continue or Ctrl+C to cancel..."
        full_setup
        touch ~/.termux/.gcp_configured
    fi
    
    main_menu
}

main
