#!/data/data/com.termux/files/usr/bin/bash

# ==============================================
#     VLESS GCP DEPLOYER - FULL UI AUTOMATION
#     github.com/qkc404/gcp
# ==============================================

# --- Colors ---
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
WHITE='\033[1;37m'
RESET='\033[0m'

# --- Activation ---
ACTIVATION_FILE="$HOME/.termux/.gcp_activated"
VALID_TOKEN="PRVTSPYYY404"

show_banner() {
    clear
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo -e "${BOLD}${CYAN}   VLESS GCP DEPLOYER - FULL AUTO       ${RESET}"
    echo -e "${BOLD}${CYAN}   github.com/qkc404/gcp                ${RESET}"
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo ""
}

check_activation() {
    [ -f "$ACTIVATION_FILE" ] && return 0 || return 1
}

activate_script() {
    clear
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo -e "${BOLD}${CYAN}   VLESS GCP DEPLOYER - ACTIVATION      ${RESET}"
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    echo ""
    echo -e "${WHITE}Enter activation code:${RESET}"
    echo ""
    
    local attempts=0
    while [ $attempts -lt 5 ]; do
        read -p "$(echo -e "${CYAN}[?]${RESET} Code: ")" USER_TOKEN
        if [ "$USER_TOKEN" = "$VALID_TOKEN" ]; then
            echo -e "${GREEN}[OK]${RESET} Activated!"
            mkdir -p "$HOME/.termux"
            echo "activated_on=$(date)" > "$ACTIVATION_FILE"
            sleep 1
            return 0
        fi
        attempts=$((attempts + 1))
        echo -e "${RED}[ERROR]${RESET} Invalid. $((5 - attempts)) attempts left."
    done
    exit 1
}

# ==============================================
#        UI AUTOMATION ENGINE (HIDDEN POWER)
# ==============================================

# Dump UI hierarchy and search for elements
dump_ui() {
    if command -v uiautomator &> /dev/null; then
        uiautomator dump /sdcard/ui.xml 2>/dev/null || true
        echo "/sdcard/ui.xml"
    elif command -v adb &> /dev/null; then
        adb shell uiautomator dump /sdcard/ui.xml 2>/dev/null || true
        adb pull /sdcard/ui.xml /tmp/ui.xml 2>/dev/null || true
        echo "/tmp/ui.xml"
    else
        echo ""
    fi
}

# Click on element containing text
click_by_text() {
    local search_text="$1"
    local ui_file=$(dump_ui)
    
    if [ -n "$ui_file" ] && [ -f "$ui_file" ]; then
        # Extract bounds for element containing the text
        local bounds=$(grep -i "$search_text" "$ui_file" 2>/dev/null | grep -o 'bounds="\[[0-9]*,[0-9]*\]\[[0-9]*,[0-9]*\]"' | head -1)
        
        if [ -n "$bounds" ]; then
            local coords=$(echo "$bounds" | sed 's/.*\[\([0-9]*\),\([0-9]*\)\]\[\([0-9]*\),\([0-9]*\)\].*/\1 \2 \3 \4/')
            local x1=$(echo "$coords" | cut -d' ' -f1)
            local y1=$(echo "$coords" | cut -d' ' -f2)
            local x2=$(echo "$coords" | cut -d' ' -f3)
            local y2=$(echo "$coords" | cut -d' ' -f4)
            local cx=$(( (x1 + x2) / 2 ))
            local cy=$(( (y1 + y2) / 2 ))
            
            echo -e "${CYAN}[*]${RESET} Clicking '$search_text' at ($cx, $cy)"
            input tap $cx $cy 2>/dev/null || true
            rm -f "$ui_file" 2>/dev/null
            return 0
        fi
        rm -f "$ui_file" 2>/dev/null
    fi
    return 1
}

# Click checkbox if present
click_checkbox() {
    local ui_file=$(dump_ui)
    if [ -n "$ui_file" ] && [ -f "$ui_file" ]; then
        if grep -q "checkbox\|CheckBox" "$ui_file" 2>/dev/null; then
            # Check if unchecked (no 'checked' attribute)
            if ! grep -q "checked=\"true\"" "$ui_file" 2>/dev/null; then
                click_by_text "checkbox"
                return 0
            fi
        fi
        rm -f "$ui_file" 2>/dev/null
    fi
    return 1
}

# Open Cloud Shell via 3-dots menu
open_cloudshell_menu() {
    echo -e "${CYAN}[*]${RESET} Looking for Cloud Shell activation..."
    
    # Try direct Cloud Shell URL first
    am start -a android.intent.action.VIEW -d "https://console.cloud.google.com/cloudshell/open" 2>/dev/null || true
    sleep 1
    
    # Try to find and click 3-dots menu
    click_by_text "more_vert" || click_by_text "More" || input tap 1000 200 2>/dev/null || true
    sleep 1
    
    # Try to find and click Cloud Shell
    click_by_text "Cloud Shell" || click_by_text "cloudshell" || click_by_text ">_" || input tap 1000 350 2>/dev/null || true
    
    echo -e "${GREEN}[OK]${RESET} Cloud Shell activation attempted."
}

# Complete welcome flow
complete_welcome_flow() {
    echo -e "${CYAN}[*]${RESET} Scanning for welcome dialogs..."
    
    # Wait for page load
    sleep 3
    
    # Click "Got it" / "Accept" / "Continue" on welcome
    click_by_text "Got it" || click_by_text "Accept" || click_by_text "Continue" || click_by_text "OK" || click_by_text "Next"
    sleep 1
    
    # Check and click any checkboxes (Terms of Service)
    click_checkbox
    sleep 1
    
    # Click "Agree" or "Continue"
    click_by_text "Agree" || click_by_text "Agree and Continue" || click_by_text "Continue" || click_by_text "Accept"
    sleep 2
    
    echo -e "${GREEN}[OK]${RESET} Welcome flow completed."
}

# ==============================================
#        GOOGLE CLOUD SDK FUNCTIONS
# ==============================================

check_gcloud() {
    export PATH="$PREFIX/google-cloud-sdk/bin:$PATH" 2>/dev/null || true
    command -v gcloud &> /dev/null && return 0 || return 1
}

check_auth() {
    gcloud auth list --format="value(account)" 2>/dev/null | grep -q "@" && return 0 || return 1
}

install_gcloud() {
    show_banner
    if check_gcloud; then
        echo -e "${GREEN}[OK]${RESET} gcloud already installed."
        read -p "Press Enter to return..."
        return
    fi
    
    echo -e "${YELLOW}[*]${RESET} Installing Google Cloud SDK..."
    pkg install python qrencode -y > /dev/null 2>&1 || true
    curl -L https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-arm.tar.gz -o $PREFIX/tmp/gcloud.tar.gz 2>/dev/null || true
    mkdir -p $PREFIX/tmp
    cd $PREFIX/tmp
    tar -xzf gcloud.tar.gz 2>/dev/null || true
    mv google-cloud-sdk $PREFIX/ 2>/dev/null || true
    rm -f gcloud.tar.gz
    cd $HOME
    $PREFIX/google-cloud-sdk/install.sh --quiet --usage-reporting=false --path-update=false 2>/dev/null || true
    export PATH="$PREFIX/google-cloud-sdk/bin:$PATH"
    echo 'export PATH="$PREFIX/google-cloud-sdk/bin:$PATH"' >> ~/.bashrc
    echo 'export CLOUDSDK_PYTHON="$PREFIX/bin/python"' >> ~/.bashrc
    source ~/.bashrc 2>/dev/null || true
    python -m pip install --quiet six 2>/dev/null || true
    echo -e "${GREEN}[OK]${RESET} Google Cloud SDK installed."
    read -p "Press Enter to return..."
}

authenticate() {
    show_banner
    check_gcloud || { echo -e "${RED}[ERROR]${RESET} gcloud not installed."; read -p "Press Enter..."; return; }
    echo -e "${YELLOW}[*]${RESET} Authenticating..."
    gcloud auth login --no-launch-browser || echo -e "${RED}[ERROR]${RESET} Auth failed."
    read -p "Press Enter to return..."
}

set_project() {
    show_banner
    check_gcloud || { echo -e "${RED}[ERROR]${RESET} gcloud not installed."; read -p "Press Enter..."; return; }
    echo -e "${YELLOW}[?]${RESET} Enter Project ID:"
    read -p "Project ID: " PROJECT_ID
    [ -n "$PROJECT_ID" ] && gcloud config set project "$PROJECT_ID" && echo -e "${GREEN}[OK]${RESET} Project set."
    read -p "Press Enter to return..."
}

# ==============================================
#        DEPLOYMENT FUNCTIONS
# ==============================================

quick_deploy() {
    show_banner
    check_gcloud || { echo -e "${RED}[ERROR]${RESET} gcloud not installed."; read -p "Press Enter..."; return; }
    check_auth || { echo -e "${RED}[ERROR]${RESET} Not authenticated."; read -p "Press Enter..."; return; }
    
    echo -e "${YELLOW}[*]${RESET} FULL UI AUTOMATION MODE"
    echo ""
    echo -e "${CYAN}[?]${RESET} Paste Qwiklabs fallback URL:"
    read -p "URL: " LAB_URL
    
    if [ -n "$LAB_URL" ]; then
        echo -e "${BOLD}${GREEN}>>> RECEIVED!${RESET}"
        echo -e "${CYAN}[*]${RESET} Opening lab in browser..."
        termux-open-url "$LAB_URL" 2>/dev/null || true
        echo -e "${CYAN}[*]${RESET} Waiting for page load..."
        sleep 5
        
        echo -e "${YELLOW}[*]${RESET} Starting UI automation..."
        complete_welcome_flow
        sleep 2
        open_cloudshell_menu
    fi
    
    echo ""
    echo -e "${CYAN}=========================================${RESET}"
    echo -e "${WHITE}>>> PLEASE AUTHORIZE CLOUD SHELL <<<${RESET}"
    echo -e "${CYAN}=========================================${RESET}"
    echo ""
    read -p "Press Enter AFTER authorization is complete..."
    echo ""
    echo -e "${YELLOW}[*]${RESET} Deploying via Cloud Shell..."
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    DEPLOY_OUTPUT=$(gcloud cloud-shell ssh --authorize-session --command="curl -sL https://raw.githubusercontent.com/qkc404/gcp/main/deploy.sh -o deploy.sh && chmod +x deploy.sh && echo -e 'prvtspyyy404\n4\n3' | ./deploy.sh 2>&1" 2>/dev/null || true)
    
    echo "$DEPLOY_OUTPUT"
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    VLESS_URI=$(echo "$DEPLOY_OUTPUT" | grep -o "vless://[^[:space:]]*" | head -1)
    if [ -n "$VLESS_URI" ]; then
        echo ""
        echo -e "${BOLD}${GREEN}VLESS URI:${RESET}"
        echo -e "${CYAN}$VLESS_URI${RESET}"
        echo ""
        echo -e "${YELLOW}[*]${RESET} QR Code:"
        echo "$VLESS_URI" | qrencode -t ANSIUTF8 2>/dev/null || echo -e "${YELLOW}[!]${RESET} Install qrencode for QR display."
    fi
    
    echo -e "${GREEN}[OK]${RESET} Deployment complete."
    read -p "Press Enter to return..."
}

custom_deploy() {
    show_banner
    check_gcloud || { echo -e "${RED}[ERROR]${RESET} gcloud not installed."; read -p "Press Enter..."; return; }
    check_auth || { echo -e "${RED}[ERROR]${RESET} Not authenticated."; read -p "Press Enter..."; return; }
    
    echo -e "${YELLOW}[*]${RESET} Custom Deployment"
    read -p "Service name [prvtspyyy404]: " SNAME; SNAME="${SNAME:-prvtspyyy404}"
    echo -e "${CYAN}Select CPU/RAM:${RESET}"
    echo "  [1] 1v1G [2] 1v2G [3] 2v2G [4] 2v4G [5] 4v4G"
    read -p "Choice [4]: " CPURAM; CPURAM="${CPURAM:-4}"
    read -p "Output [1=QR 2=Ping 3=Both] [3]: " OUTPUT; OUTPUT="${OUTPUT:-3}"
    
    echo -e "${CYAN}[?]${RESET} Paste Qwiklabs fallback URL:"
    read -p "URL: " LAB_URL
    
    if [ -n "$LAB_URL" ]; then
        echo -e "${BOLD}${GREEN}>>> RECEIVED!${RESET}"
        termux-open-url "$LAB_URL" 2>/dev/null || true
        sleep 5
        complete_welcome_flow
        open_cloudshell_menu
    fi
    
    echo ""
    echo -e "${CYAN}=========================================${RESET}"
    echo -e "${WHITE}>>> PLEASE AUTHORIZE CLOUD SHELL <<<${RESET}"
    echo -e "${CYAN}=========================================${RESET}"
    echo ""
    read -p "Press Enter AFTER authorization is complete..."
    
    echo -e "${YELLOW}[*]${RESET} Deploying..."
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    DEPLOY_OUTPUT=$(gcloud cloud-shell ssh --authorize-session --command="curl -sL https://raw.githubusercontent.com/qkc404/gcp/main/deploy.sh -o deploy.sh && chmod +x deploy.sh && echo -e '$SNAME\n$CPURAM\n$OUTPUT' | ./deploy.sh 2>&1" 2>/dev/null || true)
    
    echo "$DEPLOY_OUTPUT"
    echo -e "${BOLD}${CYAN}=========================================${RESET}"
    
    VLESS_URI=$(echo "$DEPLOY_OUTPUT" | grep -o "vless://[^[:space:]]*" | head -1)
    if [ -n "$VLESS_URI" ]; then
        echo -e "${BOLD}${GREEN}VLESS URI:${RESET}"
        echo -e "${CYAN}$VLESS_URI${RESET}"
        echo "$VLESS_URI" | qrencode -t ANSIUTF8 2>/dev/null
    fi
    
    echo -e "${GREEN}[OK]${RESET} Deployment complete."
    read -p "Press Enter to return..."
}

full_setup() {
    install_gcloud
    authenticate
    set_project
    show_banner
    echo -e "${GREEN}[OK]${RESET} Full setup complete!"
    read -p "Press Enter to return..."
}

# ==============================================
#        MAIN MENU
# ==============================================

main_menu() {
    while true; do
        show_banner
        echo -e "${BOLD}${CYAN}              MAIN MENU                 ${RESET}"
        echo -e "${BOLD}${CYAN}=========================================${RESET}"
        echo ""
        echo -e "  ${BOLD}[1]${RESET} Full Setup (Install Everything)"
        echo -e "  ${BOLD}[2]${RESET} Authenticate / Set Project"
        echo -e "  ${BOLD}[3]${RESET} Quick Deploy (FULL UI AUTOMATION)"
        echo -e "  ${BOLD}[4]${RESET} Custom Deploy"
        echo -e "  ${BOLD}[5]${RESET} Exit"
        echo ""
        read -p "Select option [1-5]: " CHOICE
        
        case $CHOICE in
            1) full_setup ;;
            2) authenticate; set_project ;;
            3) quick_deploy ;;
            4) custom_deploy ;;
            5) echo -e "${GREEN}Goodbye.${RESET}"; exit 0 ;;
            *) echo -e "${RED}Invalid choice.${RESET}"; sleep 1 ;;
        esac
    done
}

# ==============================================
#        ENTRY POINT
# ==============================================

if ! check_activation; then
    activate_script
fi

# Install uiautomator if not present
command -v uiautomator &> /dev/null || pkg install uiautomator -y > /dev/null 2>&1 || true

main_menu
